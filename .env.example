# ============================================================
# Flywheel Web — 環境變數範本
# 複製此檔案為 .env.local 並填入真實值，.env.local 不進 git
# ============================================================

# ── 資料庫 ──────────────────────────────────────────────────
# flywheel-bot SQLite 資料庫路徑
FLYWHEEL_DB_PATH=/home/benjamin/Projects/flywheel-bot/flywheel.db

# ── 認證 ────────────────────────────────────────────────────
# JWT 簽名密鑰（隨機字串，至少 32 字元）
FLYWHEEL_AUTH_SECRET=your-random-secret-here

# ── Clerk 認證 ───────────────────────────────────────────────
# https://dashboard.clerk.com → 取得以下值
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Telegram Bot ─────────────────────────────────────────────
# 主 bot（@BotFather 取得）
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Admin bot（可與主 bot 相同）
TELEGRAM_ADMIN_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 管理員 Telegram Chat ID
ADMIN_TELEGRAM_CHAT_ID=your_chat_id

# ── Infini 支付 ──────────────────────────────────────────────
# https://openapi.infini.money → API 管理
INFINI_KEY_ID=your_key_id
INFINI_SECRET_KEY=your_secret_key
INFINI_BASE_URL=https://openapi.infini.money
INFINI_WEBHOOK_PUBLIC_KEY=your_webhook_public_key

# ── Anthropic ────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxx

# ── PostHog 分析 ─────────────────────────────────────────────
# https://app.posthog.com → Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── 部署 Webhook ─────────────────────────────────────────────
# 用於 GitHub Actions → 觸發伺服器部署
DEPLOY_WEBHOOK_SECRET=your-deploy-webhook-secret

# ── 外部腳本路徑 ─────────────────────────────────────────────
# flywheel-bot 腳本路徑（本機部署時使用）
FLYWHEEL_SCAN_SCRIPT=/home/benjamin/Projects/flywheel-bot/scripts/web-scan.js
FLYWHEEL_OPP_SCRIPT=/home/benjamin/Projects/flywheel-bot/scripts/web-opportunity.js

# ── 應用名稱 ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Flywheel
